<muclient>
<plugin
   name="Note_to_Clipboard"
   author="Robbo"
   id="71a4d99aaaf91765aa81a959"
   language="Lua"
   purpose="Copies note contents to the clipboard"
   save_state="y"
   date_written="2026-04-26 08:30:00"
   requires="5.07"
   version="1.0"
   >

</plugin>


<!--  Triggers  -->

<triggers>
  <trigger
   enabled="y"
   match="~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~"
   name="trg_noteDivider"
   regexp="n"
   send_to="12"
   sequence="100"
   script="captureDivider"
  >
  </trigger>
  <trigger
   enabled="y"
   match="From    : *"
   name="trg_noteFrom"
   regexp="n"
   send_to="12"
   sequence="100"
   script="captureHeader"
  >
  </trigger>
  <trigger
   enabled="y"
   match="Forum   : *"
   name="trg_noteForum"
   regexp="n"
   send_to="12"
   sequence="100"
   script="captureHeader"
  >
  </trigger>
  <trigger
   enabled="y"
   match="To      : *"
   name="trg_noteTo"
   regexp="n"
   send_to="12"
   sequence="100"
   script="captureHeader"
  >
  </trigger>
  <trigger
   enabled="y"
   match="Date    : *"
   name="trg_noteDate"
   regexp="n"
   send_to="12"
   sequence="100"
   script="captureHeader"
  >
  </trigger>
  <trigger
   enabled="n"
   match="*"
   name="trg_noteBody"
   regexp="n"
   send_to="12"
   sequence="200"
   script="captureBody"
  >
  </trigger>
</triggers>

<!--  Aliases  -->

<aliases>
  <alias
   match="^copynote$"
   enabled="y"
   regexp="y"
   send_to="12"
   sequence="100"
   script="copyNoteClipboard"
  >
  </alias>
</aliases>

<!--  Variables  -->

<variables>

</variables>

<script>
<![CDATA[
plugin_path = string.match(GetPluginInfo(GetPluginID(), 6), "(.*)\\.*$") .. "\\lua\\"
package.path = plugin_path .. "?;" .. plugin_path .. "?.lua;" .. package.path

require "serialize"
require "captureNote"
]]>
</script>


</muclient>
